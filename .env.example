# Copy to .env for local runs: cp .env.example .env
# Real environment variables take precedence over .env values.

HOST=127.0.0.1
PORT=8787

# Disconnect visitors who stay away or inactive (milliseconds). Default: 1800000 (30 minutes). 0 disables.
INACTIVE_DISCONNECT_MS=1800000

# How often the server scans for inactive visitors (milliseconds). Default: 60000 (1 minute).
INACTIVE_CHECK_INTERVAL_MS=60000

# Origins allowed to embed the self-hosted (no siteKey) widget, comma-separated.
# Each entry is an exact origin (scheme + host, no trailing slash). A connection
# whose page Origin is not listed is closed with "origin not allowed". A request
# whose Origin host equals the server's own Host is always allowed, so same-origin
# pages need no entry. Leave unset to reject all cross-origin embeds.
#
# A single `*` wildcard is supported for hosts whose subdomain changes per
# deploy (e.g. Oxygen preview URLs). The `*` stands in for one host label
# segment (>=1 char, no dots); the rest is matched literally. It is scheme-locked,
# the part after the `*` must be a real domain (>=2 labels, never a bare TLD), and
# anchoring makes look-alikes like myshopify.dev.evil.com impossible. Prefer the
# tightest form your hosting allows — pin to the stable per-project suffix rather
# than the whole platform:
#   https://*-6cab3d0bdc2950366dcf.myshopify.dev   # only this project's previews
#   https://*.myshopify.dev                        # any Shopify preview (looser)
# ALLOWED_ORIGINS=https://shop.example,https://*-6cab3d0bdc2950366dcf.myshopify.dev

# Per-IP abuse limits, scoped independently to each site. Set any limit to 0 to disable it.
IP_MAX_IDENTITIES=2
IP_JOIN_LIMIT=30
IP_STATE_EVENT_LIMIT=600
IP_CHAT_EVENT_LIMIT=20

# Quarantine an IP when multiple identities repeat the same action in synchronized rounds. Set rounds or duration to 0 to disable.
IP_SYNC_ACTION_ROUNDS=3
IP_SYNC_ACTION_WINDOW_MS=10000
IP_SYNC_ACTION_TOLERANCE_MS=250
IP_QUARANTINE_MS=600000

# Drop chat messages sent within this many ms of joining (scripted enter-say-leave abuse). 0 disables.
MIN_HUMAN_SAY_MS=1500
# Global cap on outbound Telegram notifications per minute across all sites. 0 disables.
TELEGRAM_MAX_NOTIFICATIONS_PER_MIN=20
# Proof-of-work difficulty (leading zero bits) for the per-site bot-protection gate.
# Owners enable bot protection per site in the admin; this tunes the client cost.
POW_DIFFICULTY_BITS=15

# Local dev tooling (/dev, /walk-sandbox). Leave unset in production.
ENABLE_DEV_TOOLS=1

# Optional
# DATA_DIR=.data
# PUBLIC_ORIGIN=https://your-domain.example
# LANDING_ORIGIN=https://your-landing-domain.example
# SERVICE_ADMIN_PASSWORD=
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
#
# Plausible analytics (server-side injection; leave unset to disable)
# PLAUSIBLE_DOMAIN=your-domain.example
# PLAUSIBLE_SCRIPT_SRC=/js/script.js
# PLAUSIBLE_API_PATH=/api/event
# PLAUSIBLE_UPSTREAM=https://plausible.io
